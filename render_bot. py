# render_bot.py
import os
import sys
import logging
from threading import Thread
from flask import Flask
from telegram.ext import ApplicationBuilder, CommandHandler

# --- Configuration du logging ---
logging.basicConfig(
    format='%(asctime)s - %(name)s - %(levelname)s - %(message)s',
    level=logging.INFO
)
logger = logging.getLogger(__name__)

# --- Ton Token (directement dans le code pour l'instant) ---
BOT_TOKEN = "8342446918:AAG4cuQKWZypIeAmfTy45PB0r7hQ8QFjhqo"

# --- Les Handlers de ton bot ---
async def start(update, context):
    await update.message.reply_text('🚀 Bot Taoussi actif sur Render!')

async function(update, context): # Placeholder
    pass

# --- Création de l'application Flask (obligatoire pour Render) ---
app = Flask(__name__)

@app.route('/')
def index():
    return "✅ Bot Taoussi is running on Render!"

@app.route('/health')
def health():
    return "OK", 200

# --- Fonction pour lancer le bot en parallèle ---
def run_bot():
    # Créer l'application du bot
    telegram_app = ApplicationBuilder().token(BOT_TOKEN).build()
    telegram_app.add_handler(CommandHandler("start", start))
    # telegram_app.add_handler(CommandHandler("graph", graph)) # Ajoute tes commandes ici

    logger.info("🚀 Bot polling démarré...")
    telegram_app.run_polling()

# --- Point d'entrée principal ---
if __name__ == "__main__":
    # Lancer le bot dans un thread séparé
    bot_thread = Thread(target=run_bot)
    bot_thread.start()
    logger.info("🚀 Serveur Flask démarré...")
    # Lancer le serveur Flask sur le port donné par Render
    port = int(os.environ.get('PORT', 5000))
    app.run(host='0.0.0.0', port=port)
