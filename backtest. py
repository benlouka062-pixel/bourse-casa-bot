    print("\n" + "="*60)
    print("📊 BACKTEST MULTI-ACTIONS")
    print("="*60)
    
    for sym in actions:
        print(f"\n🔍 {sym}")
        bt = Backtest(sym, date_debut)
        resultat = bt.strategie_rsi_cross()
        
        if resultat:
            print(f"  📈 Stratégie: {resultat['rendement_strategie']}%")
            print(f"  💰 Achat simple: {resultat['rendement_achat']}%")
            print(f"  🎯 Trades: {resultat['nombre_trades']} ({resultat['ratio_victoire']}% gagnants)")
            print(f"  📉 Drawdown max: {resultat['max_drawdown']}%")

